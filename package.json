    "@types/file-saver": "^2.0.7",
    "axios": "^1.13.6",
    "echarts": "^5.6.0",
    "element-plus": "^2.13.3",
    "file-saver": "^2.0.5",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/amap-js-api": "^1.4.16",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.39.3",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.10",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^6.0.11",
    "sass": "^1.97.3",
    "typescript": "~5.8.3",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vue-tsc": "^2.2.12"
