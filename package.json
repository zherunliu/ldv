{
  "name": "ldv",
  "private": true,
  "version": "1.0.0",
  "author": "github.com/zherunliu",
  "description": "NOT a Vue3 learning demo project, including sentry sdk",
  "license": "MIT",
  "keywords": [
    "Learn",
    "NOT a Demo",
    "Vue3",
    "Sentry SDK"
  ],
  "scripts": {
    "prepare": "husky",
    "lint": "concurrently \"pnpm lint:client\" \"pnpm lint:sentry\"",
    "lint:client": "pnpm --filter client lint",
    "lint:sentry": "eslint ./packages --quiet --ext .js,.jsx,.ts,.tsx --fix",
    "format": "concurrently \"pnpm format:client\" \"pnpm format:sentry\"",
    "format:client": "pnpm --filter client format",
    "format:sentry": "prettier --write ./packages",
    "build": "concurrently \"pnpm build:client\" \"pnpm build:sentry\"",
    "build:client": "pnpm --filter client build",
    "build:sentry": "rollup -c ./rollup.config.js",
    "dev": "concurrently \"pnpm dev:client\" \"pnpm dev:sentry\"",
    "dev:client": "pnpm --filter client dev",
    "dev:sentry": "rollup -c ./rollup.config.js -w",
    "mock": "pnpm --filter client mock"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "globals": "^17.0.0",
    "typescript-eslint": "^8.52.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.4.0",
    "rollup-plugin-esbuild": "^6.2.1"
  },
  "type": "module",
  "lint-staged": {
    "client/**/*.{vue,js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "packages/**/*.{js,ts}": [
      "eslint --fix"
    ],
    "*.{vue,js,ts,jsx,tsx,json,css,less,scss,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
